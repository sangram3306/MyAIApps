{
  "expo": {
    "name": "SP One",
    "slug": "tupuchat",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tupuchat",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/brand/sp_one_opening_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "android": {
      "package": "com.tupuchat.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/sp_one_opening_logo.png",
        "backgroundColor": "#000000"
      },
      "splash": {
        "image": "./assets/brand/sp_one_opening_logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
