{
  "expo": {
    "name": "CineTrack AI",
    "slug": "cinetrack-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cinetrackai",
    "userInterfaceStyle": "dark",
    "icon": "./assets/brand/cinetrack-ai-app-icon.png",
    "android": {
      "package": "com.cinetrack.ai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/cinetrack-ai-app-icon.png",
        "backgroundColor": "#050506"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050506",
          "image": "./assets/brand/cinetrack-ai-app-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5f792713-7c10-484b-83b1-a4625e139304"
      }
    },
    "ios": {
      "bundleIdentifier": "com.cinetrack.ai"
    }
  }
}
