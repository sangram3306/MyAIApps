{
  "expo": {
    "name": "CineTrack AI",
    "slug": "cinetrack-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cinetrackai",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.cinetrack.ai"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050506"
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
